<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_pos" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_interface_section']" position="after">
                <block title="POS Auto Invoice" id="pos_auto_invoice">
                    <setting string="Auto-check Invoice"
                             help="Automatically select the invoice option on the payment screen.">
                        <field name="pos_auto_invoice_check"/>
                    </setting>
                    <setting string="Disable Invoice Download"
                             help="Prevent the automatic PDF download after the payment is validated.">
                        <field name="pos_disable_auto_invoice_download"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>