<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_pos_default_customer" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.pos.default.customer</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@id='pos_interface_section']" position="inside">
                    <setting id="pos_default_customer_setting"
                             title="PoS Default Customer"
                             help="Automatically sets a default customer on the PoS interface.">
                        <field name="pos_default_customer" options="{'no_edit': True, 'no_create': True, 'no_open': True}"/>
                    </setting>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
